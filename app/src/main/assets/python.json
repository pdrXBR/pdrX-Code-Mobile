{
  "language": "python",
  "extends": null,

  "patterns": {
    "keyword": "\\b(False|None|True|and|as|assert|async|await|break|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|nonlocal|not|or|pass|raise|return|try|while|with|yield)\\b",
    "builtin": "\\b(abs|all|any|ascii|bin|bool|breakpoint|bytearray|bytes|callable|chr|classmethod|compile|complex|delattr|dict|dir|divmod|enumerate|eval|exec|filter|float|format|frozenset|getattr|globals|hasattr|hash|help|hex|id|input|int|isinstance|issubclass|iter|len|list|locals|map|max|memoryview|min|next|object|oct|open|ord|pow|print|property|range|repr|reversed|round|set|setattr|slice|sorted|staticmethod|str|sum|super|tuple|type|vars|zip)\\b",
    "string": "\"([^\"\\\\]|\\\\.)*\"|'([^'\\\\]|\\\\.)*'",
    "number": "\\b\\d+(\\.\\d+)?\\b",
    "comment": "#.*"
  },

  "colors": {
    "keyword": "#569CD6",
    "builtin": "#4EC9B0",
    "string": "#CE9178",
    "number": "#B5CEA8",
    "comment": "#6A9955",
    "default": "#D4D4D4"
  },

  "keywords": {
    "def": {
      "name": "def",
      "description": "Define uma função",
      "syntax": "def nome():",
      "example": "def soma(a, b): return a + b"
    },
    "class": {
      "name": "class",
      "description": "Define uma classe",
      "syntax": "class Nome:",
      "example": "class Pessoa:"
    },
    "if": {
      "name": "if",
      "description": "Condicional",
      "syntax": "if condição:",
      "example": "if x > 0:"
    },
    "for": {
      "name": "for",
      "description": "Loop de repetição",
      "syntax": "for item in lista:",
      "example": "for i in range(10):"
    },
    "while": {
      "name": "while",
      "description": "Loop condicional",
      "syntax": "while condição:",
      "example": "while x < 10:"
    },
    "import": {
      "name": "import",
      "description": "Importa módulo",
      "syntax": "import modulo",
      "example": "import os"
    },
    "return": {
      "name": "return",
      "description": "Retorna valor",
      "syntax": "return valor",
      "example": "return resultado"
    }
  },

  "functions": {
    "print": {
      "name": "print",
      "description": "Exibe no console",
      "syntax": "print(valor)",
      "example": "print('Hello World')"
    },
    "len": {
      "name": "len",
      "description": "Tamanho de objeto",
      "syntax": "len(obj)",
      "example": "len(lista)"
    },
    "range": {
      "name": "range",
      "description": "Sequência numérica",
      "syntax": "range(inicio, fim)",
      "example": "for i in range(5):"
    },
    "input": {
      "name": "input",
      "description": "Entrada do usuário",
      "syntax": "input(msg)",
      "example": "nome = input('Digite seu nome')"
    },
    "int": {
      "name": "int",
      "description": "Converte para inteiro",
      "syntax": "int(valor)",
      "example": "int('10')"
    },
    "str": {
      "name": "str",
      "description": "Converte para string",
      "syntax": "str(valor)",
      "example": "str(10)"
    },
    "float": {
      "name": "float",
      "description": "Converte para decimal",
      "syntax": "float(valor)",
      "example": "float('10.5')"
    },
    "list": {
      "name": "list",
      "description": "Cria lista",
      "syntax": "list(iterável)",
      "example": "list(range(5))"
    },
    "dict": {
      "name": "dict",
      "description": "Cria dicionário",
      "syntax": "dict()",
      "example": "dict(a=1, b=2)"
    }
  },

  "characters": {}
}